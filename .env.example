# RRR Clinic API — Environment Variables
# Copy this to .env and fill in your keys. Never commit .env to git.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Groq API key — get free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# GitHub Personal Access Token — for GPT-4o vision via GitHub Models
# Create at https://github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=your_github_token_here

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# LLM model selection (defaults shown)
GROQ_MODEL=llama3-70b-8192
GITHUB_MODEL=gpt-4o

# Storage paths (defaults shown — change if deploying with a volume)
CHROMA_PATH=./data/chroma_db
MEDASSIST_DATA_DIR=./data/drug_guides
CHROMA_COLLECTION=rrr_clinic_drugs

# Server port (Azure Container Apps sets this automatically)
PORT=8000

# Upload temp dir
UPLOAD_DIR=/tmp/rrr_clinic_uploads

# W&B model monitoring (MLOps Day 3) — optional, leave blank to disable
WANDB_API_KEY=
WANDB_PROJECT=rrr-clinic-medassist
WANDB_ENTITY=
